# ============================================================
# WEDDING PLANNER — ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# Password for the PostgreSQL database
# Use a strong random string — this is only used internally between containers
DB_PASSWORD=change_me_to_something_random_123

# ------------------------------------------------------------
# NEXTAUTH
# ------------------------------------------------------------
# Secret used to sign session tokens — must be a long random string
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# The URL your app is accessible at
# Local dev:
NEXTAUTH_URL=http://localhost:3000
# Production example:
# NEXTAUTH_URL=https://wedding.yourdomain.com

# ------------------------------------------------------------
# INITIAL ADMIN ACCOUNTS (seed on first run only)
# ------------------------------------------------------------
# These are used once when the database is first created
# to set up your two admin accounts. After first run they
# can be left as-is or removed — they won't overwrite
# existing users.

SEED_ADMIN_1_NAME=Alex Smith
SEED_ADMIN_1_EMAIL=alex@example.com
SEED_ADMIN_1_PASSWORD=change_me_strong_password_1

SEED_ADMIN_2_NAME=Jordan Smith
SEED_ADMIN_2_EMAIL=jordan@example.com
SEED_ADMIN_2_PASSWORD=change_me_strong_password_2

# ------------------------------------------------------------
# SMTP (for RSVP emails and payment reminders)
# ------------------------------------------------------------
# --- Gmail example (use an App Password, not your real password)
# To create a Gmail App Password:
# Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM=yourgmail@gmail.com

# --- Outlook / Hotmail example
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=you@outlook.com
# SMTP_PASS=your_password
# SMTP_FROM=you@outlook.com

# --- Mailgun example (recommended for production)
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@mg.yourdomain.com
# SMTP_PASS=your_mailgun_smtp_password
# SMTP_FROM=wedding@yourdomain.com

# --- Disable email entirely (logs to console instead — useful for dev)
# SMTP_HOST=
# SMTP_PASS=
# SMTP_USER=
# SMTP_PORT=
# SMTP_FROM=noreply@localhost

# ------------------------------------------------------------
# RATE LIMITING (optional)
# ------------------------------------------------------------
# All rate limit settings have sensible defaults — you can leave these unset.
# For multi-instance deployments, see src/lib/rate-limit.ts documentation.

# Email sending rate limit (per authenticated user)
# Default: 50 emails per hour
# EMAIL_RATE_LIMIT_MAX=50
# EMAIL_RATE_LIMIT_WINDOW_MINUTES=60

# Public RSVP endpoint rate limits (per IP and per token)
# IP limit prevents scraping; token limit prevents enumeration/spam
# Default: 20 per IP per minute, 10 per token per minute
# RSVP_RATE_LIMIT_IP_MAX=20
# RSVP_RATE_LIMIT_IP_WINDOW_SECONDS=60
# RSVP_RATE_LIMIT_TOKEN_MAX=10
# RSVP_RATE_LIMIT_TOKEN_WINDOW_SECONDS=60

# ------------------------------------------------------------
# BULK OPERATION LIMITS (optional)
# ------------------------------------------------------------
# Maximum number of items that can be processed in a single bulk operation
# These prevent DoS via oversized batch requests

# Bulk guest operations (status changes, meal assignments)
# Default: 500 guests
# BULK_GUEST_LIMIT=500

# Bulk email operations (RSVP email sends)
# Default: 100 emails
# BULK_EMAIL_LIMIT=100

# ------------------------------------------------------------
# REDIS (optional but recommended for multi-instance)
# ------------------------------------------------------------
# Redis is used for rate limiting across multiple app instances.
# For single-instance deployments, rate limiting falls back to in-memory.
# Leave unset for single-instance (in-memory fallback).
#
# For multi-instance deployments, set to your Redis URL:
# REDIS_URL=redis://localhost:6379
#
# With password:
# REDIS_URL=redis://:password@localhost:6379

# ------------------------------------------------------------
# EMAIL VERIFICATION (optional)
# ------------------------------------------------------------
# Require new admin users to verify their email before logging in
# When enabled, a verification email is sent when an admin creates a new user
# Default: false (users can log in immediately after creation)
# EMAIL_VERIFICATION_REQUIRED=false

# ------------------------------------------------------------
# GRACEFUL SHUTDOWN (optional)
# ------------------------------------------------------------
# Time in seconds to wait for in-flight requests to complete before forcing shutdown
# During this time, the app stops accepting new connections but finishes existing requests
# Default: 30 seconds
# GRACEFUL_TIMEOUT=30

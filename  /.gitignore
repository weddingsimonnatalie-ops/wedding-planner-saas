# ============================================================
# WEDDING PLANNER — .gitignore
# ============================================================
 
# ------------------------------------------------------------
# SECRETS — never commit these
# ------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
 
# ------------------------------------------------------------
# PERSISTENT DATA — never commit these
# Contains live database files and uploaded contracts/invoices
# Copy the ./data/ folder manually when moving to production
# ------------------------------------------------------------
data/
 
# ------------------------------------------------------------
# NEXT.JS
# ------------------------------------------------------------
.next/
out/
build/
dist/
 
# ------------------------------------------------------------
# NODE
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
 
# ------------------------------------------------------------
# PRISMA GENERATED CLIENT
# ------------------------------------------------------------
src/generated/
prisma/generated/
 
# ------------------------------------------------------------
# DOCKER LOCAL OVERRIDES
# ------------------------------------------------------------
docker-compose.override.yml
 
# ------------------------------------------------------------
# LOGS
# ------------------------------------------------------------
*.log
logs/
 
# ------------------------------------------------------------
# MACOS
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
 
# ------------------------------------------------------------
# WINDOWS
# ------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
 
# ------------------------------------------------------------
# EDITORS
# ------------------------------------------------------------
.idea/
*.swp
*.swo
*~
 
# VS Code — uncomment if you don't want to share editor settings
# .vscode/
 
# ------------------------------------------------------------
# TYPESCRIPT
# ------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts
 
# ------------------------------------------------------------
# MISC
# ------------------------------------------------------------
.vercel
.turbo
coverage/
.nyc_output/
 
backup-*.sql

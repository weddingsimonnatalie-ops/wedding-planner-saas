generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// --- USERS ---

enum UserRole {
  ADMIN
  VIEWER
  RSVP_MANAGER
}

model User {
  id                       String          @id @default(cuid())
  email                    String          @unique
  name                     String?
  // role REMOVED — role is now per-wedding on WeddingMember
  twoFactorEnabled         Boolean         @default(false)
  twoFactorSecret          String?
  lockedUntil              DateTime?
  sessionVersion           Int             @default(0)
  emailVerified            DateTime?
  verificationToken        String?
  verificationTokenExpires DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  weddings       WeddingMember[]
  backupCodes    BackupCode[]
  assignedTasks  Task[]
  sessions       Session[]
  accounts       Account[]
  trustedDevices TrustedDevice[]
}

model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName String
  deviceType String
  browser    String
  os         String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  ipAddress  String?
  userAgent  String?

  @@index([userId])
}

// --- WEDDING / MULTI-TENANCY ---

enum SubStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

enum BillingProvider {
  STRIPE
  PAYPAL
}

model Wedding {
  id                   String          @id @default(cuid())
  coupleName           String          @default("Our Wedding")
  weddingDate          DateTime?
  reminderEmail        String?
  sessionTimeout       Int             @default(30)
  sessionWarningTime   Int             @default(5)
  themeHue             Int             @default(330)
  currencySymbol       String          @default("£")
  totalBudget         Float?          // Overall wedding budget
  timezone            String          @default("Europe/London")  // IANA timezone for date calculations

  // Stripe
  stripeCustomerId     String?         @unique
  stripeSubscriptionId String?         @unique

  // Billing (provider-agnostic)
  billingProvider      BillingProvider @default(STRIPE)
  paypalSubscriptionId String?         @unique
  subscriptionStatus   SubStatus       @default(TRIALING)
  subscriptionPlan     String?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  gracePeriodEndsAt    DateTime?

  // Event name configuration
  ceremonyEnabled        Boolean @default(true)
  ceremonyName           String  @default("Ceremony")
  ceremonyLocation       String?
  mealEnabled            Boolean @default(true)
  mealName               String  @default("Wedding Breakfast")
  mealLocation           String?
  eveningPartyEnabled    Boolean @default(true)
  eveningPartyName       String  @default("Evening Reception")
  eveningPartyLocation   String?
  rehearsalDinnerEnabled Boolean @default(false)
  rehearsalDinnerName    String  @default("Rehearsal Dinner")
  rehearsalDinnerLocation String?

  // Per-event meal configuration
  ceremonyMealsEnabled      Boolean @default(false)
  mealMealsEnabled          Boolean @default(true)
  eveningPartyMealsEnabled Boolean @default(false)
  rehearsalDinnerMealsEnabled Boolean @default(false)

  // Data retention
  cancelledAt          DateTime?
  deleteScheduledAt    DateTime?

  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  members               WeddingMember[]
  invites               WeddingInvite[]
  guests                Guest[]
  tables                Table[]
  rooms                 Room[]
  roomElements          RoomElement[]
  suppliers             Supplier[]
  payments              Payment[]
  appointments          Appointment[]
  tasks                 Task[]
  mealOptions           MealOption[]
  planningCategories    PlanningCategory[]
  attachments           Attachment[]
  timelineEvents        TimelineEvent[]
  timelineCategories    TimelineCategory[]
  playlists             Playlist[]
}

model WeddingMember {
  id        String   @id @default(cuid())
  userId    String
  weddingId String
  role      UserRole @default(VIEWER)
  joinedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@unique([userId, weddingId])
  @@index([userId])
  @@index([weddingId])
}

model WeddingInvite {
  id        String    @id @default(cuid())
  weddingId String
  token     String    @unique @default(cuid())
  role      UserRole  @default(RSVP_MANAGER)
  email     String?
  expiresAt DateTime
  usedAt    DateTime?
  usedBy    String?
  createdAt DateTime  @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}

model StripeEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  eventType   String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model PayPalEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  eventType   String
  processedAt DateTime @default(now())
}

// Singleton global config — always has exactly one row with id = "global"
model AppConfig {
  id                   String  @id @default("global")
  registrationsEnabled Boolean @default(true)
}

// --- GUESTS ---

model Guest {
  id              String     @id @default(cuid())
  weddingId       String
  wedding         Wedding    @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  email           String?
  phone           String?
  groupName       String?
  isChild         Boolean    @default(false)
  rsvpToken       String     @unique @default(cuid())
  rsvpStatus      RsvpStatus @default(PENDING)
  rsvpRespondedAt DateTime?

  invitedToCeremony          Boolean  @default(true)
  invitedToReception         Boolean  @default(true)
  invitedToAfterparty        Boolean  @default(false)
  invitedToRehearsalDinner   Boolean  @default(false)
  attendingCeremony          Boolean?
  attendingReception         Boolean?
  attendingAfterparty        Boolean?
  attendingRehearsalDinner   Boolean?

  mealChoice   String?
  dietaryNotes String?
  mealChoices  GuestMealChoice[]

  tableId    String?
  table      Table?  @relation(fields: [tableId], references: [id])
  seatNumber Int?

  isManualOverride Boolean @default(false)

  unsubscribedAt DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weddingId])
  @@index([tableId])
  @@index([email])
  @@index([weddingId, groupName])
  @@index([weddingId, rsvpStatus])
  @@index([weddingId, email])
}

enum RsvpStatus {
  PENDING
  ACCEPTED
  PARTIAL
  DECLINED
}

model GuestMealChoice {
  id           String      @id @default(cuid())
  guestId      String
  guest        Guest       @relation(fields: [guestId], references: [id], onDelete: Cascade)
  eventId      String      // "ceremony", "meal", "eveningParty", "rehearsalDinner"
  mealOptionId String?
  mealOption   MealOption? @relation(fields: [mealOptionId], references: [id], onDelete: SetNull)

  @@unique([guestId, eventId])
  @@index([guestId])
  @@index([mealOptionId])
}

model MealOption {
  id          String  @id @default(cuid())
  weddingId   String
  wedding     Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  eventId     String  // "ceremony", "meal", "eveningParty", "rehearsalDinner"
  name        String
  description String?
  course      String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  guestChoices GuestMealChoice[]

  @@unique([weddingId, eventId, name])
  @@index([weddingId, eventId])
}

// --- SEATING ---

model Room {
  id           String        @id @default(cuid())
  weddingId    String
  wedding      Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name         String        @default("Main Reception")
  widthMetres  Float         @default(20)
  heightMetres Float         @default(15)
  tables       Table[]
  elements     RoomElement[]
  createdAt    DateTime      @default(now())

  @@index([weddingId])
}

model Table {
  id          String      @id @default(cuid())
  weddingId   String
  wedding     Wedding     @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  roomId      String
  room        Room        @relation(fields: [roomId], references: [id])
  name        String
  shape       TableShape  @default(ROUND)
  capacity    Int         @default(8)
  positionX   Float       @default(0)
  positionY   Float       @default(0)
  rotation    Float       @default(0)
  width       Float       @default(60)
  height      Float       @default(60)
  locked      Boolean     @default(false)
  colour      String      @default("#e2e8f0")
  orientation Orientation @default(VERTICAL)
  guests      Guest[]
  notes       String?
  createdAt   DateTime    @default(now())

  @@index([weddingId])
}

enum TableShape {
  ROUND
  RECTANGULAR
  OVAL
}

enum Orientation {
  HORIZONTAL
  VERTICAL
}

model RoomElement {
  id        String  @id @default(cuid())
  weddingId String
  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  roomId    String
  room      Room    @relation(fields: [roomId], references: [id])
  type      String
  label     String?
  positionX Float
  positionY Float
  width     Float   @default(10)
  height    Float   @default(10)
  rotation  Float   @default(0)
  color     String  @default("#e2e8f0")
  locked    Boolean @default(false)

  @@index([weddingId])
}

// --- SUPPLIER CATEGORIES ---

model PlanningCategory {
  id              String        @id @default(cuid())
  weddingId       String
  wedding         Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name            String
  colour          String        @default("#6366f1")
  sortOrder       Int           @default(0)
  isActive        Boolean       @default(true)
  allocatedAmount Float?
  suppliers       Supplier[]
  appointments    Appointment[]
  tasks           Task[]
  createdAt       DateTime      @default(now())

  @@index([weddingId])
}

// --- SUPPLIERS ---

model Supplier {
  id               String            @id @default(cuid())
  weddingId        String
  wedding          Wedding           @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  categoryId       String?
  category         PlanningCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name             String
  contactName      String?
  email            String?
  phone            String?
  website          String?
  notes            String?
  contractValue    Float?
  contractSigned   Boolean           @default(false)
  contractSignedAt DateTime?
  status           SupplierStatus    @default(ENQUIRY)
  bookedAt         DateTime?
  payments         Payment[]
  attachments      Attachment[]
  appointments     Appointment[]
  tasks            Task[]
  timelineEvents   TimelineEvent[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([weddingId])
}

// --- APPOINTMENTS ---

model Appointment {
  id           String               @id @default(cuid())
  weddingId    String
  wedding      Wedding              @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  title        String
  categoryId   String?
  category     PlanningCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  date         DateTime
  location     String?
  notes        String?
  supplierId   String?
  supplier     Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  reminderDays Int?
  reminderSent Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([weddingId])
  @@index([date])
  @@index([weddingId, date])
}

enum SupplierStatus {
  ENQUIRY
  QUOTED
  BOOKED
  CANCELLED
  COMPLETE
}

model Payment {
  id         String        @id @default(cuid())
  weddingId  String
  wedding    Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  label      String
  amount     Float
  dueDate    DateTime?
  paidDate   DateTime?
  status     PaymentStatus @default(PENDING)
  notes      String?
  createdAt  DateTime      @default(now())

  @@index([weddingId])
  @@index([status, dueDate])
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Attachment {
  id         String   @id @default(cuid())
  weddingId  String
  wedding    Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  paymentId  String?
  filename   String
  storedAs   String
  mimeType   String
  sizeBytes  Int
  uploadedAt DateTime @default(now())

  @@index([weddingId])
  @@index([paymentId])
}

// --- TASKS ---

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum RecurringInterval {
  DAILY
  WEEKLY
  FORTNIGHTLY
  MONTHLY
}

model Task {
  id          String       @id @default(cuid())
  weddingId   String
  wedding     Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  title       String
  notes       String?
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  isCompleted Boolean      @default(false)

  categoryId String?
  category   PlanningCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  isRecurring       Boolean            @default(false)
  recurringInterval RecurringInterval?
  recurringEndDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weddingId])
  @@index([isCompleted, dueDate])
  @@index([assignedToId])
  @@index([categoryId])
  @@index([supplierId])
}

// --- TIMELINE ---

model TimelineCategory {
  id             String         @id @default(cuid())
  weddingId      String
  wedding        Wedding        @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name           String
  colour         String         @default("#6366f1")
  sortOrder      Int            @default(0)
  isActive       Boolean        @default(true)
  timelineEvents TimelineEvent[]
  createdAt      DateTime       @default(now())

  @@index([weddingId])
}

model TimelineEvent {
  id           String            @id @default(cuid())
  weddingId    String
  wedding      Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  startTime    DateTime
  durationMins Int               @default(30)

  title        String
  location     String?
  notes        String?

  categoryId   String?
  category     TimelineCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  supplierId   String?
  supplier     Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([weddingId])
  @@index([weddingId, startTime])
}

// --- MUSIC PLAYLISTS ---

model Playlist {
  id          String   @id @default(cuid())
  weddingId   String
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tracks      Track[]

  @@index([weddingId])
}

model Track {
  id          String   @id @default(cuid())
  playlistId  String
  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  title       String
  artist      String?
  durationSec Int?
  url         String?
  notes       String?
  albumArt    String?
  deezerUrl   String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([playlistId])
}

// --- SECURITY ---

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  success   Boolean
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// --- BETTER AUTH TABLES ---

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId            String
  providerId           String
  accessToken          String?
  refreshToken         String?
  idToken              String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  password             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

// --- ADMIN CONSOLE ---

model AdminAuditLog {
  id         String   @id @default(cuid())
  action     String
  weddingId  String
  operatorId String
  before     Json?
  after      Json?
  note       String?
  createdAt  DateTime @default(now())

  @@index([weddingId])
  @@index([createdAt])
}

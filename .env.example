# ============================================================
# WEDDING PLANNER — ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# Password for the PostgreSQL database
# Use a strong random string — this is only used internally between containers
DB_PASSWORD=change_me_to_something_random_123

# ------------------------------------------------------------
# NEXTAUTH
# ------------------------------------------------------------
# Secret used to sign session tokens — must be a long random string
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# The URL your app is accessible at
# Local dev:
NEXTAUTH_URL=http://localhost:3000
# Production example:
# NEXTAUTH_URL=https://wedding.yourdomain.com

# ------------------------------------------------------------
# INITIAL ADMIN ACCOUNTS (seed on first run only)
# ------------------------------------------------------------
# These are used once when the database is first created
# to set up your two admin accounts. After first run they
# can be left as-is or removed — they won't overwrite
# existing users.

SEED_ADMIN_1_NAME=Alex Smith
SEED_ADMIN_1_EMAIL=alex@example.com
SEED_ADMIN_1_PASSWORD=change_me_strong_password_1

SEED_ADMIN_2_NAME=Jordan Smith
SEED_ADMIN_2_EMAIL=jordan@example.com
SEED_ADMIN_2_PASSWORD=change_me_strong_password_2

# ------------------------------------------------------------
# EMAIL (Resend — for RSVP emails, reminders, invites)
# ------------------------------------------------------------
# Sign up at https://resend.com — free tier is 3,000 emails/month
# Create an API key in the Resend dashboard and add it here
RESEND_API_KEY=re_your_api_key_here

# The "from" address for all outgoing emails
# Must be from a domain you have verified in Resend
# (or use onboarding@resend.dev for testing)
SMTP_FROM=wedding@yourdomain.com

# --- Disable email entirely (logs to console instead — useful for dev)
# Leave RESEND_API_KEY unset and emails will be logged to console only

# ------------------------------------------------------------
# RATE LIMITING (optional)
# ------------------------------------------------------------
# All rate limit settings have sensible defaults — you can leave these unset.
# For multi-instance deployments, see src/lib/rate-limit.ts documentation.

# Email sending rate limit (per authenticated user)
# Default: 50 emails per hour
# EMAIL_RATE_LIMIT_MAX=50
# EMAIL_RATE_LIMIT_WINDOW_MINUTES=60

# Public RSVP endpoint rate limits (per IP and per token)
# IP limit prevents scraping; token limit prevents enumeration/spam
# Default: 20 per IP per minute, 10 per token per minute
# RSVP_RATE_LIMIT_IP_MAX=20
# RSVP_RATE_LIMIT_IP_WINDOW_SECONDS=60
# RSVP_RATE_LIMIT_TOKEN_MAX=10
# RSVP_RATE_LIMIT_TOKEN_WINDOW_SECONDS=60

# ------------------------------------------------------------
# BULK OPERATION LIMITS (optional)
# ------------------------------------------------------------
# Maximum number of items that can be processed in a single bulk operation
# These prevent DoS via oversized batch requests

# Bulk guest operations (status changes, meal assignments)
# Default: 500 guests
# BULK_GUEST_LIMIT=500

# Bulk email operations (RSVP email sends)
# Default: 100 emails
# BULK_EMAIL_LIMIT=100

# ------------------------------------------------------------
# REDIS (optional but recommended for multi-instance)
# ------------------------------------------------------------
# Redis is used for rate limiting across multiple app instances.
# For single-instance deployments, rate limiting falls back to in-memory.
# Leave unset for single-instance (in-memory fallback).
#
# For multi-instance deployments, set to your Redis URL:
# REDIS_URL=redis://localhost:6379
#
# With password:
# REDIS_URL=redis://:password@localhost:6379

# ------------------------------------------------------------
# EMAIL VERIFICATION (optional)
# ------------------------------------------------------------
# Require new admin users to verify their email before logging in
# When enabled, a verification email is sent when an admin creates a new user
# Default: false (users can log in immediately after creation)
# EMAIL_VERIFICATION_REQUIRED=false

# ------------------------------------------------------------
# GRACEFUL SHUTDOWN (optional)
# ------------------------------------------------------------
# Time in seconds to wait for in-flight requests to complete before forcing shutdown
# During this time, the app stops accepting new connections but finishes existing requests
# Default: 30 seconds
# GRACEFUL_TIMEOUT=30

# ------------------------------------------------------------
# PAYPAL BILLING (optional — alternative to Stripe)
# ------------------------------------------------------------
# Sign up at https://developer.paypal.com → My Apps & Credentials
# Create a REST API app to get Client ID and Secret
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Environment: "sandbox" for testing, "live" for production
PAYPAL_MODE=sandbox

# Create a webhook in the PayPal dashboard pointing to:
#   https://yourdomain.com/api/webhooks/paypal
# Subscribe to: BILLING.SUBSCRIPTION.CREATED, BILLING.SUBSCRIPTION.ACTIVATED,
# BILLING.SUBSCRIPTION.CANCELLED, BILLING.SUBSCRIPTION.SUSPENDED,
# BILLING.SUBSCRIPTION.EXPIRED, BILLING.SUBSCRIPTION.PAYMENT.FAILED, PAYMENT.SALE.COMPLETED
PAYPAL_WEBHOOK_ID=your_webhook_id_here

# Create a billing plan with a 14-day trial cycle followed by a monthly regular cycle
# See: https://developer.paypal.com/docs/api/subscriptions/v1/#plans_create
PAYPAL_PLAN_ID_STANDARD=your_plan_id_here

# ------------------------------------------------------------
# S3-COMPATIBLE FILE STORAGE
# ------------------------------------------------------------
# In production, Railway Buckets (Tigris) auto-injects AWS_ENDPOINT_URL,
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_S3_BUCKET_NAME, and
# AWS_DEFAULT_REGION automatically — you do not need to set these in Railway.
#
# For local dev, docker-compose sets these to MinIO defaults automatically.
# You only need to set them here if running the app outside Docker.
#
# AWS_ENDPOINT_URL=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_S3_BUCKET_NAME=wedding-planner-uploads
# AWS_DEFAULT_REGION=auto

# S3_FORCE_PATH_STYLE: set to "true" for local MinIO (uses http://host/bucket/key paths).
# Leave unset in Railway — Tigris requires virtual-hosted style (false).
# docker-compose sets this to "true" automatically for local dev.
# S3_FORCE_PATH_STYLE=true

# S3_PUBLIC_ENDPOINT_URL: overrides the hostname in presigned download URLs so browsers
# can reach MinIO directly. Required when the app runs inside Docker but the browser is
# outside it (MinIO's Docker hostname is not browser-resolvable).
# Set to your machine's LAN IP, e.g. http://192.168.6.249:9000
# Leave unset in Railway — Tigris presigned URLs are already publicly accessible.
# S3_PUBLIC_ENDPOINT_URL=http://192.168.6.249:9000

# ------------------------------------------------------------
# AI TIMELINE GENERATION (Ollama Cloud)
# ------------------------------------------------------------
# Create an API key at https://ollama.com/settings/keys
# Required for the "Generate timeline" feature (ACTIVE/PAST_DUE subscribers only).
# Leave unset to disable AI generation — all other features work normally.
OLLAMA_API_KEY=your_ollama_api_key_here

# ============================================================
# WEDDING PLANNER SAAS — ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# Password for the PostgreSQL database.
# Use a strong random string — only used internally between containers.
DB_PASSWORD=change_me_to_something_random_123

# App database connection (via PgBouncer in production, direct in dev).
# In docker-compose dev these are auto-set — only override for Railway.
# DATABASE_URL=postgresql://wedding:DB_PASSWORD@pgbouncer:5432/railway
# DIRECT_DATABASE_URL=postgresql://wedding:DB_PASSWORD@postgres:5432/railway

# ------------------------------------------------------------
# AUTH
# ------------------------------------------------------------
# Secret used to sign session tokens and the weddingId cookie.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# The public URL your app is accessible at.
# Must match exactly — used for auth redirects and RSVP email links.
# Local dev:
NEXTAUTH_URL=http://localhost:3001
# Production (Railway / Cloudflare Tunnel):
# NEXTAUTH_URL=https://app.yourdomain.com

# ------------------------------------------------------------
# STRIPE BILLING
# ------------------------------------------------------------
# Obtain from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Create a product + monthly price in Stripe dashboard, then paste the price ID here.
STRIPE_PRICE_ID_STANDARD=price_...

# Webhook secret — from Stripe dashboard or `stripe listen` output.
STRIPE_WEBHOOK_SECRET=whsec_...

# Billing lifecycle settings (days)
TRIAL_DAYS=14
GRACE_PERIOD_DAYS=7
DATA_RETENTION_DAYS=90

# ------------------------------------------------------------
# PAYPAL BILLING (optional — alternative to Stripe)
# ------------------------------------------------------------
# Sign up at https://developer.paypal.com → My Apps & Credentials
# Create a REST API app to get Client ID and Secret
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Environment: "sandbox" for testing, "live" for production
PAYPAL_MODE=sandbox

# Create a webhook in the PayPal dashboard pointing to:
#   https://yourdomain.com/api/webhooks/paypal
# Subscribe to: BILLING.SUBSCRIPTION.CREATED, BILLING.SUBSCRIPTION.ACTIVATED,
# BILLING.SUBSCRIPTION.CANCELLED, BILLING.SUBSCRIPTION.SUSPENDED,
# BILLING.SUBSCRIPTION.EXPIRED, BILLING.SUBSCRIPTION.PAYMENT.FAILED, PAYMENT.SALE.COMPLETED
PAYPAL_WEBHOOK_ID=your_webhook_id_here

# Create a billing plan with a 14-day trial cycle followed by a monthly regular cycle
# See: https://developer.paypal.com/docs/api/subscriptions/v1/#plans_create
PAYPAL_PLAN_ID_STANDARD=your_plan_id_here

# ------------------------------------------------------------
# S3-COMPATIBLE FILE STORAGE
# ------------------------------------------------------------
# Production: Railway Buckets auto-injects these vars — no manual config needed.
# Local dev: docker-compose defaults to MinIO (no config needed).
AWS_ENDPOINT_URL=https://...
AWS_DEFAULT_REGION=auto
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET_NAME=wedding-planner-uploads

# ------------------------------------------------------------
# REDIS
# ------------------------------------------------------------
# Used for cache (categories, settings) and rate limiting across replicas.
# Local dev: docker-compose sets this automatically (no config needed).
# Production (Railway): add the Redis plugin, then in your app service env vars set:
#   REDIS_URL=${{Redis.REDIS_PRIVATE_URL}}
# REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# INNGEST (background jobs — optional)
# ------------------------------------------------------------
# Controls how background jobs run:
#
#   INNGEST_EVENT_KEY not set (default):
#     A reminder daemon subprocess runs inside the container.
#     Works correctly with a single replica. Simplest option.
#
#   INNGEST_EVENT_KEY set:
#     Daemon is skipped. Inngest (inngest.com) handles all background
#     jobs externally. Required if running multiple replicas.
#
# To use Inngest: create a free account at inngest.com, create an app,
# and copy the Event Key and Signing Key here.
# INNGEST_EVENT_KEY=...
# INNGEST_SIGNING_KEY=...

# ------------------------------------------------------------
# EMAIL (Resend)
# ------------------------------------------------------------
# Sign up at https://resend.com — free tier is 3,000 emails/month.
# Create an API key in the Resend dashboard and paste it here.
# If unset, emails log to console instead of sending (useful for dev).
RESEND_API_KEY=re_your_api_key_here

# The "from" address for all outgoing emails.
# Must be from a domain you have verified in Resend.
# (Use onboarding@resend.dev for testing before domain verification.)
SMTP_FROM=wedding@yourdomain.com

# ------------------------------------------------------------
# RATE LIMITING (optional — defaults shown)
# ------------------------------------------------------------
EMAIL_RATE_LIMIT_MAX=50
EMAIL_RATE_LIMIT_WINDOW_MINUTES=60
RSVP_RATE_LIMIT_IP_MAX=20
RSVP_RATE_LIMIT_IP_WINDOW_SECONDS=60
RSVP_RATE_LIMIT_TOKEN_MAX=10
RSVP_RATE_LIMIT_TOKEN_WINDOW_SECONDS=60
BULK_GUEST_LIMIT=500
BULK_EMAIL_LIMIT=100

# ------------------------------------------------------------
# CLOUDFLARE TUNNEL (optional — production only)
# ------------------------------------------------------------
# Used by the cloudflared service (docker-compose --profile prod).
CLOUDFLARE_TUNNEL_TOKEN=

# ------------------------------------------------------------
# ADMIN CONSOLE INTEGRATION (optional)
# ------------------------------------------------------------
# Shared secret used to authenticate requests from the admin console to the
# SaaS app's internal API endpoints (e.g. /api/internal/cancel-subscription).
# Generate with: openssl rand -base64 32
# Must match the ADMIN_INTERNAL_SECRET value in the admin console's .env.
# ADMIN_INTERNAL_SECRET=generate_with_openssl_rand_base64_32

# ------------------------------------------------------------
# MISC
# ------------------------------------------------------------
GRACEFUL_TIMEOUT=30
